# DB_PATH для локального запуска (через go run)
DB_PATH=postgres://postgres:password@localhost:5432/subscriptions?sslmode=disable

# DB_PATH для Docker Compose (раскомментировать при использовании Docker)
# DB_PATH=postgres://postgres:mysecret@db:5432/subscriptions?sslmode=disable

SERVER_PORT=8080

# PostgreSQL credentials (для Docker Compose)
POSTGRES_PASSWORD=mysecret
POSTGRES_DB=subscriptions